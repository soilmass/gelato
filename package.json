{
  "name": "@neopolitan/gelato",
  "version": "0.1.0",
  "description": "The dogmatic, eval-verified Claude Code kit for modern full-stack TypeScript. A Neopolitan product.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.0",
  "engines": {
    "bun": ">=1.1.0"
  },
  "workspaces": ["packages/*", "docs"],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "eval": "bun run scripts/eval.ts",
    "new-skill": "bun run scripts/new-skill.ts",
    "validate": "bun run scripts/validate-skills.ts",
    "docs:generate": "bun run scripts/generate-docs.ts",
    "docs:dev": "bun --cwd docs run dev",
    "docs:build": "bun --cwd docs run build",
    "publint": "bunx publint && bunx publint packages/schema && bunx publint packages/eval-harness",
    "check:publish": "bunx changeset status --verbose",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@commitlint/lint": "^19.5.0",
    "@commitlint/load": "^19.5.0",
    "@commitlint/types": "^19.5.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.48.2",
    "@types/bun": "^1.1.14",
    "lefthook": "^1.8.5",
    "promptfoo": "^0.90.0",
    "publint": "^0.2.12",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "minisearch": "^7.1.2",
    "zod": "^3.23.8"
  }
}
